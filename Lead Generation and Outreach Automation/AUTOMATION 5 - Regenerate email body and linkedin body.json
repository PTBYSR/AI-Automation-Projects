    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  try {\n    // 1. Navigate to the deeply nested 'text' string\n    const rawString = item.json.content.parts[0].text;\n\n    // 2. Parse that string into a real JSON object\n    const parsedJson = JSON.parse(rawString);\n\n    // 3. Return only the readable fields\n    return {\n      json: {\n        email1_subject: parsedJson.email1_subject,\n        email1_body: parsedJson.email1_body,\n        email2_subject: parsedJson.email2_subject,\n        email2_body: parsedJson.email2_body,\n        email3_subject: parsedJson.email3_subject,\n        email3_body: parsedJson.email3_body\n      }\n    };\n  } catch (error) {\n    // 4. Fallback if the LLM output is malformed\n    return {\n      json: {\n        error: \"Failed to parse LLM text output\",\n        raw: item.json.content.parts[0].text\n      }\n    };\n  }\n});"
      },
